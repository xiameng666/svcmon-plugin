#!/usr/bin/env python3
"""reverse-plugin session-start hook. Cross-platform (Windows/Linux/Mac)."""
import json, os, subprocess, sys
from datetime import datetime
from pathlib import Path

# ─── Config ───
GLOBAL_CONFIG = Path.home() / ".reverse-plugin" / "config.json"
DEFAULT_WORK_DIR = str(Path.home() / "re")

def load_config():
    if GLOBAL_CONFIG.is_file():
        try:
            return json.loads(GLOBAL_CONFIG.read_text())
        except Exception:
            pass
    return {}

cfg = load_config()
work_dir = Path(cfg.get("work_dir", DEFAULT_WORK_DIR))
sessions_dir = work_dir / "sessions"
config_dir = work_dir / ".config"

# ─── Init check ───
init_done = (config_dir / "stackplz").is_file()
try:
    subprocess.run(["svcMonitor", "--help"], capture_output=True, timeout=5)
    cli_ok = True
except Exception:
    cli_ok = False

init_done = init_done and cli_ok

# ─── Device check ───
device_status = "disconnected"
device_model = ""
try:
    r = subprocess.run(["adb", "devices", "-l"], capture_output=True, text=True, timeout=5)
    for line in r.stdout.splitlines():
        if "device product:" in line:
            device_status = "connected"
            for part in line.split():
                if part.startswith("model:"):
                    device_model = part.split(":", 1)[1]
            break
except Exception:
    pass

# ─── Stackplz on device ───
stackplz_device = False
if device_status == "connected" and init_done:
    try:
        env = os.environ.copy()
        env["MSYS_NO_PATHCONV"] = "1"
        r = subprocess.run(
            ["adb", "shell", "su -c 'ls /data/local/tmp/re/stackplz'"],
            capture_output=True, text=True, timeout=5, env=env)
        stackplz_device = r.returncode == 0 and "stackplz" in r.stdout
    except Exception:
        pass

# ─── Build context ───
# Note: session 目录由 svcMonitor run 自动创建，hook 不创建
if not init_done:
    ctx = "reverse-plugin: 未初始化。请先运行 /re:init"
else:
    lines = [
        "reverse-plugin:",
        f"- 工作目录: {work_dir}",
        f"- 输出目录: {sessions_dir}",
        f"- 设备: {device_status}" + (f" ({device_model})" if device_model else ""),
    ]
    if not stackplz_device and device_status == "connected":
        lines.append("- stackplz: 需要推送（执行 /re:svcmon 时自动推送）")
    ctx = "\\n".join(lines)

# ─── Output JSON ───
output = json.dumps({
    "hookSpecificOutput": {
        "additionalContext": ctx
    }
})
print(output)
