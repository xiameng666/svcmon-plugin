#!/usr/bin/env bash
# reverse-plugin SessionStart hook
# Lightweight: check device, create session dir, inject context
# NO pip install, NO downloads — that's /re:init's job

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# ─── Config ───
RE_HOME="${HOME}/re"
CONFIG_DIR="${RE_HOME}/.config"
SESSIONS_DIR="${RE_HOME}/sessions"

# ─── Helpers ───
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# ─── Check init status ───
init_done="false"
if [ -f "${CONFIG_DIR}/stackplz" ] && command -v svcMonitor &>/dev/null; then
    init_done="true"
fi

# ─── Check device ───
device_status="disconnected"
device_model=""
if command -v adb &>/dev/null; then
    adb_out=$(adb devices -l 2>/dev/null || true)
    if echo "$adb_out" | grep -q "device product:"; then
        device_status="connected"
        device_model=$(echo "$adb_out" | grep "device product:" | head -1 | sed 's/.*model:\([^ ]*\).*/\1/')
    fi
fi

# ─── Check stackplz on device ───
stackplz_device="false"
if [ "$device_status" = "connected" ] && [ "$init_done" = "true" ]; then
    if MSYS_NO_PATHCONV=1 adb shell "su -c 'ls /data/local/tmp/re/stackplz'" &>/dev/null 2>&1; then
        stackplz_device="true"
    fi
fi

# ─── Create session directory ───
SESSION_ID=$(date +"%Y%m%d_%H%M%S")
SESSION_DIR="${SESSIONS_DIR}/${SESSION_ID}"
if [ "$init_done" = "true" ]; then
    mkdir -p "$SESSION_DIR" 2>/dev/null || true
fi

# ─── Build context ───
context=""
if [ "$init_done" = "false" ]; then
    context+="reverse-plugin: 未初始化。请先运行 /re:init\\n"
else
    context+="reverse-plugin session:\\n"
    context+="- 工作目录: ${RE_HOME}\\n"
    context+="- session: ${SESSION_DIR}\\n"
    context+="- 设备: ${device_status}"
    [ -n "$device_model" ] && context+=" (${device_model})"
    context+="\\n"
    if [ "$stackplz_device" = "false" ] && [ "$device_status" = "connected" ]; then
        context+="- stackplz: 需要推送到设备（svcMonitor run 时会自动 push）\\n"
    fi
fi

escaped=$(escape_for_json "$context")

cat <<ENDJSON
{
  "hookSpecificOutput": {
    "additionalContext": "${escaped}"
  }
}
ENDJSON
